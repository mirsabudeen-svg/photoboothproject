# Backend base URL — when set, pairing (P01) is required before the guest flow
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1

# Event UUID from admin — required for config fetch after pairing
NEXT_PUBLIC_EVENT_ID=

# Device pairing uses POST /devices/pair (no admin key).
# Event config uses GET /events/:id/config with the device bearer token.
