# NestJS backend (used by dashboard proxy routes and the assistant)
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1
BACKEND_API_URL=http://localhost:3000/api/v1
ADMIN_API_KEY=change-me-in-production-min-32-chars-required

# OpenAI — required for /api/assistant and /api/ai/generate
OPENAI_API_KEY=
ASSISTANT_MODEL=gpt-4o-mini

NEXT_PUBLIC_PAIRING_CODE_DISPLAY=WEDDING2025

# Supabase (auth + realtime reads for admin dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Legacy anon JWT (optional if publishable key is set)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role — enables assistant audit table writes (server-only)
SUPABASE_SERVICE_ROLE_KEY=

# Postgres URL for LangGraph checkpointer (Supabase direct connection or backend DATABASE_URL)
ASSISTANT_DATABASE_URL=

# HMAC signing for mutation confirmations (defaults to ADMIN_API_KEY)
ASSISTANT_CONFIRM_SECRET=

# PostHog product analytics (no PII)
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
